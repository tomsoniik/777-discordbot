generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  discordId     String?   @unique
  steamId       String?   @unique
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  
  accounts      Account[]
  sessions      Session[]
  submissions   Submission[]
  ownedGroups   MusicGroup[] @relation("GroupOwner")
  
  ownedProjects BaseProject[] @relation("ProjectOwner")
  collabProjects BaseProject[] @relation("ProjectCollaborators")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FormTemplate {
  id          String       @id @default(cuid())
  title       String
  description String?
  category    String       // e.g. 'rust', 'cs2'
  fields      String       // JSON string z pytaniami
  createdAt   DateTime     @default(now())
  submissions Submission[]
}

model Submission {
  id             String       @id @default(cuid())
  userId         String
  formTemplateId String
  answers        String       // JSON string z odpowiedziami
  status         String       @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id])
  formTemplate FormTemplate @relation(fields: [formTemplateId], references: [id])
}

model BotConfig {
  id               String   @id @default(cuid())
  guildId          String   @unique
  applyChannelId   String?  // Gdzie wysylane sa aplikacje
  ticketCategoryId String?  // Gdzie tworzone sa tickety 
  adminRoleIds     String?  // ID ról (json)
  welcomeChannelId String?
  welcomeMessage   String?
  leaveChannelId   String?
  leaveMessage     String?
  autoRoleId       String?
  logChannelId     String?
  updatedAt        DateTime @updatedAt
}

model MusicGroup {
  id        String   @id @default(cuid())
  name      String
  guildId   String   @unique
  ownerId   String
  createdAt DateTime @default(now())

  owner   User               @relation("GroupOwner", fields: [ownerId], references: [id])
  members MusicGroupMember[]
}

model BaseProject {
  id          String   @id @default(cuid())
  name        String   @default("Nowy Projekt")
  description String?  @db.Text
  ownerId     String
  owner       User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  data        String   @default("[]") // JSON array of PlacedItem
  isPublic    Boolean  @default(false)
  joinCode    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  collaborators User[] @relation("ProjectCollaborators")
}

model MusicGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  discordId String?
  steamId   String?
  addedAt   DateTime @default(now())

  group MusicGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// ==========================================
// ECHO-TRACKER: Shadow Network Models (Read-Only sync from Bot)
// ==========================================

model PlayerNode {
  steamId      String   @id
  lastNickname String?
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
}

model PlayerRelation {
  id           Int      @id @default(autoincrement())
  steamIdA     String   
  steamIdB     String   
  bondStrength Int      @default(1)
  lastSeenTgt  DateTime @default(now())

  @@unique([steamIdA, steamIdB])
}

model SessionEncounter {
  id            Int      @id @default(autoincrement())
  targetId      String   
  bystanderId   String   
  serverIp      String
  encounteredAt DateTime @default(now())
}

model BotSettings {
  id Int @id @default(autoincrement())
}

model PlayerHistory {
  id Int @id @default(autoincrement())
}

model TrackedPlayer {
  id Int @id @default(autoincrement())
}


