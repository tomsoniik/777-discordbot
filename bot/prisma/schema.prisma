// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackedPlayer {
  id           Int      @id @default(autoincrement())
  steamId      String   @unique
  addedBy      String   // Discord User ID
  addedAt      DateTime @default(now())
  targetServer String?  // Optional specific server, or null for all
  isActive     Boolean  @default(true)
  isOnline     Boolean  @default(false)
  lastServer   String?
}

model PlayerHistory {
  id           Int      @id @default(autoincrement())
  steamId      String
  nickname     String?
  serverIp     String
  serverName   String?
  detectedAt   DateTime @default(now())
}

model BotSettings {
  id               Int     @id @default(1)
  defaultChannelId String?
}

// ==========================================
// ECHO-TRACKER: Shadow Network Models
// ==========================================

model PlayerNode {
  steamId      String   @id
  lastNickname String?
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
}

model PlayerRelation {
  id           Int      @id @default(autoincrement())
  steamIdA     String   // Alfabetically smaller steamId for uniqueness
  steamIdB     String   // Alfabetically larger steamId
  bondStrength Int      @default(1) // Goes up each time they are seen together
  lastSeenTgt  DateTime @default(now())

  @@unique([steamIdA, steamIdB])
}

model SessionEncounter {
  id           Int      @id @default(autoincrement())
  targetId     String   // The tracked player
  bystanderId  String   // The other player on the server
  serverIp     String
  encounteredAt DateTime @default(now())
}

